# Local paths. Copy this file to .env and edit as needed.
HOUSE_AGENT_CONFIG=config.yaml
HOUSE_AGENT_DB_PATH=work/house_agent.sqlite3
# On Render this is provided by Render Postgres.
# DATABASE_URL=postgresql://...

# Render-only safety: baseline current listings on first empty database run.
HOUSE_AGENT_BASELINE_ON_EMPTY_DB=false

# Gmail API OAuth files.
# Put credentials.json in the project root after creating it in Google Cloud.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=.secrets/gmail_token.json

# Render-only: paste the contents of .secrets/gmail_token.json into this env var.
# GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"..."}
